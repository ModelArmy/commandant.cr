{
  "tool": "grep",
  "tool_summary": "A search tool that reads input and outputs lines matching a regular expression pattern.",
  "platform": "posix",
  "platform_notes": "GNU grep and BSD grep share the same core flag set covered in this ruleset. Key differences: GNU grep --perl-regexp (-P) enables Perl-compatible regex, while BSD grep --perl-regexp (-P) enables POSIX extended regex (not Perl). GNU grep --line-buffered and --mmap are GNU-specific; BSD grep lacks these flags. If you need to assess Perl-regex usage, generate a linux-specific ruleset.",
  "llm_confidence": "high",
  "unknown_flags": [
    "--perl-regexp"
  ],
  "is_multiplexer": false,
  "option_abbreviations": {},
  "rules": [
    {
      "id": "grep-recursive",
      "description": "Recursive search traverses directory trees, reading all files including hidden files and symlinks (with -R). This significantly expands read scope beyond what would be accessed in a single file or directory.",
      "patterns": [
        {
          "pattern": "grep ... -r ...",
          "pattern_type": "flag",
          "example": "grep -r 'password' /etc/",
          "match": {
            "flags_any": [
              "-r",
              "--recursive"
            ]
          }
        },
        {
          "pattern": "grep ... -R ...",
          "pattern_type": "flag",
          "example": "grep -R 'secret' .",
          "match": {
            "flags_any": [
              "-R",
              "--dereference-recursive"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-r follows symlinks but -R additionally dereferences them. Both traverse directory trees recursively."
    },
    {
      "id": "grep-binary-as-text",
      "description": "Forces grep to process binary files as text, exposing binary content including embedded credentials, private keys, or other sensitive data that would otherwise be skipped by default.",
      "patterns": [
        {
          "pattern": "grep ... -a ...",
          "pattern_type": "flag",
          "example": "grep -a 'key' /usr/lib/",
          "match": {
            "flags_any": [
              "-a",
              "--text"
            ]
          }
        },
        {
          "pattern": "grep ... --binary-files=text ...",
          "pattern_type": "flag",
          "example": "grep --binary-files=text 'token' ./bin/",
          "match": {
            "flags_any": [
              "--binary-files=text"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1005"
      ],
      "notes": "Default grep behavior skips binary files. This flag overrides that protection."
    },
    {
      "id": "grep-pattern-file",
      "description": "Reads search patterns from an external file, expanding the read scope to include that file and loading patterns that may match sensitive content. May be used with untrusted pattern files.",
      "patterns": [
        {
          "pattern": "grep ... -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -f /tmp/patterns.txt myfile.txt",
          "match": {
            "flags_any": [
              "-f"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1005"
      ],
      "notes": "The pattern file itself is read as input. Each pattern inside is applied as regex (or fixed string with -F), potentially matching sensitive content."
    },
    {
      "id": "grep-invert-recursive",
      "description": "Recursive search with inverted match (-v) shows all non-matching lines across the entire tree. This can expose a volume of data approaching the total content of the searched files, making it a broad data exposure vector.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -v ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -v 'public' /project/",
          "match": {
            "flags_all": [
              "-v",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -v ... -R ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -v 'secret' -R .",
          "match": {
            "flags_all": [
              "-v",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "Both -r/-R and -v must be present. Order is flexible."
    },
    {
      "id": "grep-context-recursive",
      "description": "Recursive search with context lines (-A, -B, -C) expands output beyond matching lines, revealing surrounding content from each file. Combined with recursive search, this significantly increases data exposure beyond exact match results.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -A ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -A 10 'error' /var/log/",
          "match": {
            "flags_all": [
              "-r",
              "-A"
            ]
          }
        },
        {
          "pattern": "grep ... -r ... -B ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -B 5 'warn' /var/log/",
          "match": {
            "flags_all": [
              "-r",
              "-B"
            ]
          }
        },
        {
          "pattern": "grep ... -r ... -C ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -C 3 'test' /app/",
          "match": {
            "flags_all": [
              "-r",
              "-C"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -A ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -A 20 'fail' /opt/",
          "match": {
            "flags_all": [
              "-R",
              "-A"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -B ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -B 3 'warn' /opt/",
          "match": {
            "flags_all": [
              "-R",
              "-B"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -C ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -C 5 'error' /opt/",
          "match": {
            "flags_all": [
              "-R",
              "-C"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-A (after), -B (before), and -C (context, equals -A -B combined) each accept a numeric argument. Requires recursive flag for meaningful risk."
    },
    {
      "id": "grep-files-with-matches-recursive",
      "description": "Lists only filenames containing matches. Combined with recursive search, this traverses the entire directory tree and reveals which files contain sensitive patterns without showing the content itself. Useful for covert file enumeration across a tree.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -l ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -l 'password' /project/",
          "match": {
            "flags_all": [
              "-l",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -l ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -l 'secret' .",
          "match": {
            "flags_all": [
              "-l",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083"
      ],
      "notes": "Lists only filenames that contain at least one match. Combined with recursive, reveals the file structure of the search tree through which files match."
    },
    {
      "id": "grep-files-without-match-recursive",
      "description": "Lists filenames that do NOT contain matches. Combined with recursive search, traverses the entire tree and reveals which files do not contain sensitive patterns. Can be used to fingerprint system state from outside the target directory.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -L ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -L 'admin' /project/",
          "match": {
            "flags_all": [
              "-L",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -L ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -L 'secret' .",
          "match": {
            "flags_all": [
              "-L",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083"
      ],
      "notes": "Opposite of -l. Reveals files that not match the pattern. Can be used to enumerate file structure."
    },
    {
      "id": "grep-quiet-recursive",
      "description": "Suppresses all output. Combined with recursive search, this silently traverses directory trees reading all files without producing output. Commonly used for covert pattern verification or backdoor detection where the operator only cares about success or failure, not content.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -q ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -q 'password' /etc/",
          "match": {
            "flags_all": [
              "-q",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -q ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -q 'secret' .",
          "match": {
            "flags_all": [
              "-q",
              "-R"
            ]
          }
        },
        {
          "pattern": "grep ... --recursive ... --quiet ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep --recursive --quiet 'password' /etc/",
          "match": {
            "flags_all": [
              "--quiet",
              "--recursive"
            ]
          }
        },
        {
          "pattern": "grep ... --recursive ... --silent ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep --recursive --silent 'secret' .",
          "match": {
            "flags_all": [
              "--silent",
              "--recursive"
            ]
          }
        },
        {
          "pattern": "grep ... -r ... --quiet ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r --quiet 'admin' /var/",
          "match": {
            "flags_all": [
              "--quiet",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... --silent ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R --silent 'config' /opt/",
          "match": {
            "flags_all": [
              "--silent",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach",
        "computer-security-compromise"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-q, --quiet, and --silent suppress all output. The recursive read still occurs; only output is prevented. Often used for covert verification."
    },
    {
      "id": "grep-count-recursive",
      "description": "Shows count of matching lines per file. Combined with recursive search, reveals which files contain patterns and how many, without exposing the matched content. Can be used to fingerprint system state or detect presence of specific patterns across a tree.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -c ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -c 'password' /project/",
          "match": {
            "flags_all": [
              "-c",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -c ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -c 'secret' .",
          "match": {
            "flags_all": [
              "-c",
              "-R"
            ]
          }
        },
        {
          "pattern": "grep ... --recursive ... --count ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep --recursive --count 'password' /project/",
          "match": {
            "flags_all": [
              "--count",
              "--recursive"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-c and --count. Shows line counts per file. Combined with recursive, reveals which files in the tree contain matches."
    },
    {
      "id": "grep-null-data-recursive",
      "description": "Treats input as NUL-separated rather than newline-separated, combined with recursive search. This causes grep to read entire binary files as single null-delimited records across directory trees, significantly expanding effective read scope over binary content that would normally be processed line-by-line or skipped.",
      "patterns": [
        {
          "pattern": "grep ... -z ... -r ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -z -r 'secret' /project/",
          "match": {
            "flags_all": [
              "-z",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -z ... -R ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -z -R 'token' .",
          "match": {
            "flags_all": [
              "-z",
              "-R"
            ]
          }
        },
        {
          "pattern": "grep ... --null-data ... --recursive ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep --null-data --recursive 'secret' /project/",
          "match": {
            "flags_all": [
              "--null-data",
              "--recursive"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-z and --null-data are equivalent. Without -r/-R the standalone null-data rule applies. This rule covers the expanded binary read scope of null-delimited search across directory trees."
    },
    {
      "id": "grep-devices-read",
      "description": "Forces grep to read device files (such as /dev/sda, /dev/mem, FIFOs) as regular files. Reading device files can expose hardware state, kernel memory, or other sensitive data beyond normal file content.",
      "patterns": [
        {
          "pattern": "grep ... --devices=read ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep 'data' --devices=read /dev/sda",
          "match": {
            "flags_any": [
              "--devices=read"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "WARNING",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1005"
      ],
      "notes": "--devices=read makes grep read device files as regular files. --devices=skip explicitly prevents this behavior."
    },
    {
      "id": "grep-recursive-extract",
      "description": "Recursive search with --only-matching (-o) extracts only the matched text from every file across the entire directory tree. This produces clean, targeted output with no surrounding context — a low-noise exfiltration vector that yields only the sensitive data itself.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -o ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -o '[0-9a-f]{40}' /project/",
          "match": {
            "flags_all": [
              "-o",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -o ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -o 'password=\\\\S+' .",
          "match": {
            "flags_all": [
              "-o",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "ERROR",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "-o with recursive search extracts only matched text, producing clean output ideal for exfiltration."
    },
    {
      "id": "grep-recursive-pattern-file",
      "description": "Recursive search with -f loads search patterns from an external file and applies them across the entire directory tree. The external file may contain patterns crafted to extract sensitive content, and the recursive scope means the full tree is searched.",
      "patterns": [
        {
          "pattern": "grep ... -r ... -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -r -f /tmp/keywords.txt /data/",
          "match": {
            "flags_all": [
              "-f",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... -R ... -f ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep -R -f sensitive-patterns.txt .",
          "match": {
            "flags_all": [
              "-f",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "ERROR",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083",
        "T1005"
      ],
      "notes": "Both -r/-R and -f must be present. The pattern file itself is also read as input."
    },
    {
      "id": "grep-directories-read",
      "description": "Causes grep to read directory arguments as files, listing their contents (like ls). Combined with recursive search, this recursively lists directory contents across the tree, enabling covert file enumeration. Without -r/-R, it lists the contents of the specified directories.",
      "patterns": [
        {
          "pattern": "grep ... --directories=read ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep '' --directories=read /sensitive/path/",
          "match": {
            "flags_any": [
              "--directories=read",
              "--directories=recurse",
              "-d"
            ],
            "args_any": [
              "read",
              "recurse"
            ]
          }
        },
        {
          "pattern": "grep ... --directories=read ... -r ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep '' --directories=read -r /",
          "match": {
            "flags_all": [
              "--directories=read",
              "-r"
            ]
          }
        },
        {
          "pattern": "grep ... --directories=read ... -R ...",
          "pattern_type": "flag-argument-combination",
          "example": "grep '' --directories=read -R /home/",
          "match": {
            "flags_all": [
              "--directories=read",
              "-R"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files",
        "recursive"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "likely_consequences": [
        "privacy-breach"
      ],
      "mitre_attack": [
        "T1083"
      ],
      "notes": "Default --directories=read makes grep treat directory arguments as files, listing their entries. This is primarily a file enumeration risk. Combined with -r/-R it traverses all subdirectories. --directories=skip prevents this. --directories=recurse is equivalent to -r."
    },
    {
      "id": "grep-quiet",
      "description": "Suppresses all output. Without recursive search, this is used to check for patterns in specific files without revealing content. Can be used for covert verification of specific files.",
      "patterns": [
