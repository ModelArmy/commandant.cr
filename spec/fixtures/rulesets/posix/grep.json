          "pattern": "grep ... --color ...",
          "pattern_type": "flag",
          "example": "grep --color=always -r 'test' .",
          "match": {
            "flags_any": [
              "--color=always",
              "--color=never",
              "--color=auto",
              "--color"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "likely_consequences": [],
      "mitre_attack": []
    },
    {
      "id": "grep-no-messages",
      "description": "Suppresses error messages for inaccessible files. While this hides errors (which could be a concern for auditing), it does not expand read scope.",
      "patterns": [
        {
          "pattern": "grep ... --no-messages ...",
          "pattern_type": "flag",
          "example": "grep --no-messages -r 'secret' .",
          "match": {
            "flags_any": [
              "--no-messages",
              "-s"
            ]
          }
        }
      ],
      "risk_tags": [
        "reads-files"
      ],
      "reversible": "yes",
      "severity": "INFO",
      "likely_consequences": [],
      "mitre_attack": []
    }
  ],
